rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return me().data.role;
    }

    function isAdmin() {
      return signedIn() && (myRole() == "admin" || myRole() == "developer");
    }

    function isDeveloper() {
      return signedIn() && myRole() == "developer";
    }

    function notBanned() {
      return signedIn() && me().data.banned != true;
    }

    function developerNotBannedByUpdate() {
      return !(resource.data.role == "developer" && request.resource.data.banned == true);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        (
          request.auth.uid == userId &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.banned == resource.data.banned
        ) ||
        (isAdmin() && developerNotBannedByUpdate())
      );
      allow delete: if isDeveloper() && resource.data.role != "developer";
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn() && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if isDeveloper();
    }

    match /pushTokens/{token} {
      allow read: if isAdmin();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
    }

    match /reports/{reportId} {
      allow read: if true;
      allow create: if notBanned();
      allow update: if notBanned() || isAdmin();
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read: if true;
        allow create: if notBanned();
        allow update, delete: if isAdmin() || (signedIn() && resource.data.authorId == request.auth.uid);
      }
    }
  }
}
