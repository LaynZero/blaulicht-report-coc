rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    function isAudio() {
      return request.resource.contentType.matches('audio/.*');
    }

    // Report photos: 8 MB max, uploader-owned folder, publicly readable (reports are public).
    match /reports/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid) && (isImage() || isAudio()) && request.resource.size < 8 * 1024 * 1024;
      allow delete: if isOwner(uid);
    }

    // Profile avatars: 4 MB max, uploader-owned folder, publicly readable.
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if isOwner(uid) && isImage() && request.resource.size < 4 * 1024 * 1024;
      allow delete: if isOwner(uid);
    }

    // Everything else is closed by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
